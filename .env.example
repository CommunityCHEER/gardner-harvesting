# Firebase Configuration
# Copy this to .env and fill in your actual values
EXPO_PUBLIC_FIREBASE_API_KEY=your-api-key-here
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
EXPO_PUBLIC_FIREBASE_APP_ID=your-app-id

# Smart Harvest local service endpoint
# Android emulator: http://10.0.2.2:8080
# Android physical device via adb reverse: http://127.0.0.1:8080
# iOS simulator: http://localhost:8080
EXPO_PUBLIC_SMART_HARVEST_URL=http://10.0.2.2:8080

# When switching targets, update EXPO_PUBLIC_SMART_HARVEST_URL and restart Expo with cache clear:
# npx expo start --clear
